        "type": "function",
        "z": "49e1284654ecb233",
        "name": "function 14",
        "func": "const v = Number(msg.payload.value);\n\nif (v === 1) {\n    msg.payload = `\n    <div style=\"background:#4CAF50;\n                color:white;\n                padding:10px;\n                border-radius:8px;\n                text-align:center;\n                font-weight:bold;\">\n        🚶 MOTION DETECTED\n    </div>`;\n} else {\n    msg.payload = `\n    <div style=\"background:#9E9E9E;\n                color:white;\n                padding:10px;\n                border-radius:8px;\n                text-align:center;\">\n        No Motion\n    </div>`;\n}\n\nreturn msg;",
