        "name": "function 20",
        "func": "const mode = global.get(\"mode\") || \"Manual\";\nif (mode !== \"Static\") return null;\n\nconst smoke = Number(msg.payload.value);\nif (Number.isNaN(smoke)) return null;\n\nif (smoke !== 1) return null;\n\nmsg.topic = \"home/kitchen/actuator/fan/set\";\nmsg.payload = {\n    state: \"ON\",\n    reason: \"Static smoke detected\"\n};\n\nreturn msg;",
