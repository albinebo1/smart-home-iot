    {
        "id": "a629298931967722",
        "type": "function",
        "z": "49e1284654ecb233",
        "name": "function 17",
        "func": "if (typeof msg.payload === \"string\") {\n  try { msg.payload = JSON.parse(msg.payload); } catch (e) {}\n}\n\nconst parts = (msg.topic || \"\").split(\"/\");\nconst device = parts[3];\n\nconst raw = msg.payload && msg.payload.state;\nconst state = (raw === true || raw === \"ON\" || raw === 1) ? \"ON\" : \"OFF\";\nif (!device) return null;\n\nconst key = \"kitchen_actuator_states\";\nconst states = global.get(key) || { light: \"OFF\", ac: \"OFF\", fan: \"OFF\" };\nstates[device] = state;\nglobal.set(key, states);\n\nmsg.payload = [\n  { device: \"Light\", state: states.light },\n  { device: \"Exhaust Fan\", state: states.fan }\n];\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 440,
        "y": 1180,
        "wires": [
            [
                "ee3478aa939413e3"
            ]
        ]
    },
