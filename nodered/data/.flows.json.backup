    {
        "id": "e7c1da9379268b30",
        "type": "function",
        "z": "eb4fff834c698462",
        "name": "static LR AC rule",
        "func": "const mode = global.get(\"mode\") || \"Manual\";\nif (mode !== \"Static\") return null;\n\nconst temp = Number(msg.payload.value);\nif (Number.isNaN(temp)) return null;\n\n// hysteresis thresholds\nconst ON_AT = 27.5;\nconst OFF_AT = 24.0;\n\n// remember last AC state so we don't spam commands\nconst key = \"lr_ac_state\";\nconst prev = global.get(key) || \"OFF\";\n\nlet next = prev;\n\nif (temp >= ON_AT) next = \"ON\";\nif (temp <= OFF_AT) next = \"OFF\";\n\nif (next === prev) return null;\n\nglobal.set(key, next);\n\nmsg.topic = \"home/livingroom/actuator/ac/set\";\nmsg.payload = { state: next, reason: `static_temp_rule temp=${temp}` };\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 490,
        "y": 60,
