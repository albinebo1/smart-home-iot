        "name": "functionFirst",
        "func": "const mode = global.get(\"mode\") || \"Manual\";\nif (mode !== \"Static\") return null;\n\nconst motion = Number(msg.payload.value);\nif (Number.isNaN(motion)) return null;\n\nmsg.motion = motion;\nreturn msg;",
