    {
        "id": "c9a7a41c8c7a2792",
        "type": "function",
        "z": "eb4fff834c698462",
        "name": "function 7",
        "func": "const mode = global.get(\"mode\") || \"Manual\";\nif (mode !== \"Static\") return null;\n\nconst hum = Number(msg.payload.value);\nif (Number.isNaN(hum)) return null;\n\nconst ON_AT = 70;\nconst OFF_AT = 60;\n\nconst key = \"bathroom_fan_state\";\nconst prev = global.get(key) || \"OFF\";\n\nlet next = prev;\n\nif (hum >= ON_AT) next = \"ON\";\nif (hum <= OFF_AT) next = \"OFF\";\n\nif (next === prev) return null;\n\nglobal.set(key, next);\n\nmsg.topic = \"home/bathroom/actuator/fan/set\";\nmsg.payload = {\n    state: next,\n    reason: `Static humidity rule hum=${hum}`\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 440,
        "y": 520,
        "wires": [
