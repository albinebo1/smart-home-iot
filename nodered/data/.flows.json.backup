    {
        "id": "22e45cce85236869",
        "type": "function",
        "z": "9539bcdd3d66373d",
        "name": "function 1",
        "func": "// Ensure payload is object\nif (typeof msg.payload === \"string\") {\n  try { msg.payload = JSON.parse(msg.payload); } catch (e) {}\n}\n\nconst parts = (msg.topic || \"\").split(\"/\");\nconst room = parts[1];\nconst device = parts[3];\n\nlet raw = msg.payload && msg.payload.state;\n\n// normalize to ON/OFF\nconst state = (raw === true || raw === \"ON\" || raw === 1) ? \"ON\" : \"OFF\";\n\nmsg.topic = `home/${room}/actuator/${device}/state`;\nmsg.payload = { state, ts: Date.now() };\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
