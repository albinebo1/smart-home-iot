    {
        "id": "9aba0bef1faa7aa3",
        "type": "function",
        "z": "49e1284654ecb233",
        "name": "Light function Hallway",
        "func": "const mode = global.get(\"mode\") || \"Manual\";\n\nif (mode !== \"Manual\") {\n    // Ignore manual switches if not in manual mode\n    return null;\n} \n\n// msg.payload might be true/false or already ON/OFF\nconst v = msg.payload;\nconst state = (v === true || v === \"ON\" || v === 1) ? \"ON\" : \"OFF\";\n\nmsg.topic = \"home/hallway/actuator/light/set\";\nmsg.payload = { state };\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
