    {
        "id": "0ddddc2f3dff02ab",
        "type": "function",
        "z": "49e1284654ecb233",
        "name": "Light function Kitchen",
        "func": "const mode = global.get(\"mode\") || \"Manual\";\n\nif (mode !== \"Manual\") {\n    // Ignore manual switches if not in manual mode\n    return null;\n}\n\nconst v = msg.payload;\nconst state = (v === true || v === \"ON\" || v === 1) ? \"ON\" : \"OFF\";\n\nmsg.topic = \"home/kitchen/actuator/light/set\";\nmsg.payload = { state };\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 480,
        "y": 1040,
        "wires": [
