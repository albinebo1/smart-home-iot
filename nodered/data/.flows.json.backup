    {
        "id": "2cbef0e25c7af134",
        "type": "function",
        "z": "4f4869a9266855d4",
        "name": "function 1 - validate + format line protocol",
        "func": "const parts = msg.topic.split(\"/\");\n\nconst room = parts[1];\nconst type = parts[3];\n\nlet v = parseFloat(msg.payload.value);\nif (isNaN(v)) return null;\n\n// line protocol (tags included)\nmsg.payload = `sensor_data_v2,room=${room},type=${type} value=${v}`;\n\nmsg.headers = {\n  \"Authorization\": \"Token 2HOSt3nrZGCN0W8cWAD1k0d-thCMC9pzABQ4RM62qZqUOf-r-WRhK9rkdEesH6bKk5M39XPTzPfcYcfa3EWG5Q==\",\n  \"Content-Type\": \"text/plain\"\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 520,
        "y": 200,
        "wires": [
            [
                "3057750566c70444"
            ]
        ]
    },
